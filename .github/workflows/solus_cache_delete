name: Delete Solus Cache

on:
  workflow_dispatch:

jobs:
  delete-cache:
    runs-on: ubuntu-latest

    steps:
      - name: Delete Solus cache
        uses: actions/cache@v3
        with:
          path: /var/cache/eopkg
          key: ${{ runner.os }}-eopkg-cache-
          restore-keys: |
            ${{ runner.os }}-eopkg-cache-